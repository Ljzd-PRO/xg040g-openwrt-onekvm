+//! Disabled audio backend for constrained OpenWrt builds.
+
+use std::str::FromStr;
+use std::sync::Arc;
+use std::time::Instant;
+
+use bytes::Bytes;
+use serde::{Deserialize, Serialize};
+use tokio::sync::{broadcast, mpsc, watch, RwLock};
+
+use crate::error::{AppError, Result};
+use crate::events::EventBus;
+
+#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize, Default)]
+#[serde(rename_all = "lowercase")]
+pub enum AudioQuality {
+    Voice,
+    #[default]
+    Balanced,
+    High,
+}
+
+impl AudioQuality {
+    pub fn bitrate(&self) -> u32 {
+        match self {
+            AudioQuality::Voice => 32000,
+            AudioQuality::Balanced => 64000,
+            AudioQuality::High => 128000,
+        }
+    }
+
+    pub fn to_opus_config(&self) -> OpusConfig {
+        match self {
+            AudioQuality::Voice => OpusConfig::voice(),
+            AudioQuality::Balanced => OpusConfig::default(),
+            AudioQuality::High => OpusConfig::music(),
+        }
+    }
+}
+
+impl FromStr for AudioQuality {
+    type Err = AppError;
+
+    fn from_str(s: &str) -> std::result::Result<Self, Self::Err> {
+        match s.trim().to_lowercase().as_str() {
+            "voice" => Ok(Self::Voice),
+            "balanced" => Ok(Self::Balanced),
+            "high" => Ok(Self::High),
+            _ => Err(AppError::BadRequest(format!(
+                "invalid audio quality {:?} (expected voice, balanced, or high)",
+                s.trim()
+            ))),
+        }
+    }
+}
+
+impl std::fmt::Display for AudioQuality {
+    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
+        match self {
+            AudioQuality::Voice => write!(f, "voice"),
+            AudioQuality::Balanced => write!(f, "balanced"),
+            AudioQuality::High => write!(f, "high"),
+        }
+    }
+}
+
+#[derive(Debug, Clone)]
+pub struct AudioControllerConfig {
+    pub enabled: bool,
+    pub device: String,
+    pub quality: AudioQuality,
+}
+
+impl Default for AudioControllerConfig {
+    fn default() -> Self {
+        Self {
+            enabled: false,
+            device: String::new(),
+            quality: AudioQuality::Balanced,
+        }
+    }
+}
+
+#[derive(Debug, Clone, Serialize)]
+pub struct AudioStatus {
+    pub enabled: bool,
+    pub streaming: bool,
+    pub device: Option<String>,
+    pub quality: AudioQuality,
+    pub subscriber_count: usize,
+    pub error: Option<String>,
+}
+
+#[derive(Debug, Clone, Serialize)]
+pub struct AudioDeviceInfo {
+    pub name: String,
+    pub description: String,
+    pub card_index: i32,
+    pub device_index: i32,
+    pub sample_rates: Vec<u32>,
+    pub channels: Vec<u32>,
+    pub is_capture: bool,
+    pub is_hdmi: bool,
+    pub usb_bus: Option<String>,
+}
+
+#[derive(Debug, Clone)]
+pub struct AudioConfig {
+    pub device_name: String,
+    pub sample_rate: u32,
+    pub channels: u32,
+    pub frame_size: u32,
+    pub buffer_frames: u32,
+    pub period_frames: u32,
+}
+
+impl Default for AudioConfig {
+    fn default() -> Self {
+        Self {
+            device_name: String::new(),
+            sample_rate: 48000,
+            channels: 2,
+            frame_size: 960,
+            buffer_frames: 4096,
+            period_frames: 960,
+        }
+    }
+}
+
+impl AudioConfig {
+    pub fn for_device(device: &AudioDeviceInfo) -> Self {
+        Self {
+            device_name: device.name.clone(),
+            ..Default::default()
+        }
+    }
+
+    pub fn bytes_per_sample(&self) -> u32 {
+        2 * self.channels
+    }
+
+    pub fn bytes_per_frame(&self) -> usize {
+        (self.frame_size * self.bytes_per_sample()) as usize
+    }
+}
+
+#[derive(Debug, Clone)]
+pub struct AudioFrame {
+    pub data: Bytes,
+    pub sample_rate: u32,
+    pub channels: u32,
+    pub samples: u32,
+    pub sequence: u64,
+    pub timestamp: Instant,
+}
+
+impl AudioFrame {
+    pub fn new_interleaved(data: Bytes, channels: u32, sample_rate: u32, sequence: u64) -> Self {
+        let bps = 2 * channels;
+        Self {
+            samples: data.len() as u32 / bps,
+            data,
+            sample_rate,
+            channels,
+            sequence,
+            timestamp: Instant::now(),
+        }
+    }
+}
+
+#[derive(Debug, Clone, Copy, PartialEq, Eq)]
+pub enum CaptureState {
+    Stopped,
+    Running,
+    Error,
+}
+
+#[derive(Debug, Clone)]
+pub struct OpusConfig {
+    pub sample_rate: u32,
+    pub channels: u32,
+    pub bitrate: u32,
+    pub application: OpusApplication,
+    pub fec: bool,
+}
+
+impl Default for OpusConfig {
+    fn default() -> Self {
+        Self {
+            sample_rate: 48000,
+            channels: 2,
+            bitrate: 64000,
+            application: OpusApplication::Audio,
+            fec: true,
+        }
+    }
+}
+
+impl OpusConfig {
+    pub fn voice() -> Self {
+        Self {
+            application: OpusApplication::Voip,
+            bitrate: 32000,
+            ..Default::default()
+        }
+    }
+
+    pub fn music() -> Self {
+        Self {
+            application: OpusApplication::Audio,
+            bitrate: 128000,
+            ..Default::default()
+        }
+    }
+}
+
+#[derive(Debug, Clone, Copy, PartialEq, Eq)]
+pub enum OpusApplication {
+    Voip,
+    Audio,
+    LowDelay,
+}
+
+#[derive(Debug, Clone)]
+pub struct OpusFrame {
+    pub data: Bytes,
+    pub duration_ms: u32,
+    pub sequence: u64,
+}
+
+impl OpusFrame {
+    pub fn len(&self) -> usize {
+        self.data.len()
+    }
+
+    pub fn is_empty(&self) -> bool {
+        self.data.is_empty()
+    }
+}
+
+pub struct OpusEncoder {
+    _config: OpusConfig,
+}
+
+impl OpusEncoder {
+    pub fn new(config: OpusConfig) -> Result<Self> {
+        Ok(Self { _config: config })
+    }
+
+    pub fn encode(&mut self, _pcm_data: &[i16]) -> Result<OpusFrame> {
+        Err(AppError::AudioError(audio_disabled_message()))
+    }
+
+    pub fn encode_frame(&mut self, _frame: &AudioFrame) -> Result<OpusFrame> {
+        Err(AppError::AudioError(audio_disabled_message()))
+    }
+
+    pub fn set_bitrate(&mut self, _bitrate: u32) -> Result<()> {
+        Ok(())
+    }
+}
+
+#[derive(Debug, Clone, Copy, PartialEq, Eq, Default)]
+pub enum AudioStreamState {
+    #[default]
+    Stopped,
+    Starting,
+    Running,
+    Error,
+}
+
+#[derive(Debug, Clone, Default)]
+pub struct AudioStreamerConfig {
+    pub capture: AudioConfig,
+    pub opus: OpusConfig,
+}
+
+impl AudioStreamerConfig {
+    pub fn for_device(device_name: &str) -> Self {
+        Self {
+            capture: AudioConfig {
+                device_name: device_name.to_string(),
+                ..Default::default()
+            },
+            opus: OpusConfig::default(),
+        }
+    }
+
+    pub fn with_bitrate(mut self, bitrate: u32) -> Self {
+        self.opus.bitrate = bitrate;
+        self
+    }
+}
+
+#[derive(Debug, Clone, Default)]
+pub struct AudioStreamStats {
+    pub subscriber_count: usize,
+}
+
+pub struct AudioStreamer {
+    state_tx: watch::Sender<AudioStreamState>,
+    state_rx: watch::Receiver<AudioStreamState>,
+}
+
+impl AudioStreamer {
+    pub fn new() -> Self {
+        Self::with_config(AudioStreamerConfig::default())
+    }
+
+    pub fn with_config(_config: AudioStreamerConfig) -> Self {
+        let (state_tx, state_rx) = watch::channel(AudioStreamState::Stopped);
+        Self { state_tx, state_rx }
+    }
+
+    pub fn state(&self) -> AudioStreamState {
+        *self.state_rx.borrow()
+    }
+
+    pub fn state_watch(&self) -> watch::Receiver<AudioStreamState> {
+        self.state_rx.clone()
+    }
+
+    pub fn subscribe_opus(&self) -> mpsc::Receiver<Arc<OpusFrame>> {
+        let (_tx, rx) = mpsc::channel::<Arc<OpusFrame>>(1);
+        rx
+    }
+
+    pub fn subscriber_count(&self) -> usize {
+        0
+    }
+
+    pub fn stats(&self) -> AudioStreamStats {
+        AudioStreamStats::default()
+    }
+
+    pub async fn set_config(&self, _config: AudioStreamerConfig) -> Result<()> {
+        Ok(())
+    }
+
+    pub async fn set_bitrate(&self, _bitrate: u32) -> Result<()> {
+        Ok(())
+    }
+
+    pub async fn start(&self) -> Result<()> {
+        let _ = self.state_tx.send(AudioStreamState::Error);
+        Err(AppError::AudioError(audio_disabled_message()))
+    }
+
+    pub async fn stop(&self) -> Result<()> {
+        let _ = self.state_tx.send(AudioStreamState::Stopped);
+        Ok(())
+    }
+
+    pub fn is_running(&self) -> bool {
+        false
+    }
+}
+
+impl Default for AudioStreamer {
+    fn default() -> Self {
+        Self::new()
+    }
+}
+
+pub struct AudioCapturer {
+    state_tx: watch::Sender<CaptureState>,
+    state_rx: watch::Receiver<CaptureState>,
+    frame_tx: broadcast::Sender<AudioFrame>,
+}
+
+impl AudioCapturer {
+    pub fn new(_config: AudioConfig) -> Self {
+        let (state_tx, state_rx) = watch::channel(CaptureState::Stopped);
+        let (frame_tx, _) = broadcast::channel(1);
+        Self {
+            state_tx,
+            state_rx,
+            frame_tx,
+        }
+    }
+
+    pub fn state(&self) -> CaptureState {
+        *self.state_rx.borrow()
+    }
+
+    pub fn state_watch(&self) -> watch::Receiver<CaptureState> {
+        self.state_rx.clone()
+    }
+
+    pub fn subscribe(&self) -> broadcast::Receiver<AudioFrame> {
+        self.frame_tx.subscribe()
+    }
+
+    pub async fn start(&self) -> Result<()> {
+        let _ = self.state_tx.send(CaptureState::Error);
+        Err(AppError::AudioError(audio_disabled_message()))
+    }
+
+    pub async fn stop(&self) -> Result<()> {
+        let _ = self.state_tx.send(CaptureState::Stopped);
+        Ok(())
+    }
+}
+
+#[derive(Debug, Clone, PartialEq, Eq)]
+pub enum AudioHealthStatus {
+    Healthy,
+    Error { reason: String, error_code: String },
+}
+
+pub struct AudioHealthMonitor {
+    status: RwLock<AudioHealthStatus>,
+}
+
+impl AudioHealthMonitor {
+    pub fn new() -> Self {
+        Self {
+            status: RwLock::new(AudioHealthStatus::Healthy),
+        }
+    }
+
+    pub fn prepare_retry_attempt(&self) {}
+
+    pub async fn report_error(&self, reason: &str, error_code: &str) {
+        *self.status.write().await = AudioHealthStatus::Error {
+            reason: reason.to_string(),
+            error_code: error_code.to_string(),
+        };
+    }
+
+    pub async fn report_recovered(&self) {
+        *self.status.write().await = AudioHealthStatus::Healthy;
+    }
+
+    pub async fn reset(&self) {
+        *self.status.write().await = AudioHealthStatus::Healthy;
+    }
+
+    pub async fn status(&self) -> AudioHealthStatus {
+        self.status.read().await.clone()
+    }
+
+    pub async fn is_error(&self) -> bool {
+        matches!(*self.status.read().await, AudioHealthStatus::Error { .. })
+    }
+
+    pub async fn error_message(&self) -> Option<String> {
+        match &*self.status.read().await {
+            AudioHealthStatus::Healthy => None,
+            AudioHealthStatus::Error { reason, .. } => Some(reason.clone()),
+        }
+    }
+}
+
+impl Default for AudioHealthMonitor {
+    fn default() -> Self {
+        Self::new()
+    }
+}
+
+pub struct AudioController {
+    config: RwLock<AudioControllerConfig>,
+    event_bus: RwLock<Option<Arc<EventBus>>>,
+    recovered_callback: RwLock<Option<Arc<dyn Fn() + Send + Sync>>>,
+}
+
+impl AudioController {
+    pub fn new(config: AudioControllerConfig) -> Self {
+        Self {
+            config: RwLock::new(config),
+            event_bus: RwLock::new(None),
+            recovered_callback: RwLock::new(None),
+        }
+    }
+
+    pub async fn set_event_bus(&self, event_bus: Arc<EventBus>) {
+        *self.event_bus.write().await = Some(event_bus);
+    }
+
+    pub async fn set_recovered_callback(&self, callback: Arc<dyn Fn() + Send + Sync>) {
+        *self.recovered_callback.write().await = Some(callback);
+    }
+
+    pub async fn list_devices(&self) -> Result<Vec<AudioDeviceInfo>> {
+        Ok(Vec::new())
+    }
+
+    pub async fn get_cached_devices(&self) -> Vec<AudioDeviceInfo> {
+        Vec::new()
+    }
+
+    pub async fn select_device(&self, _device: &str) -> Result<()> {
+        Err(AppError::AudioError(audio_disabled_message()))
+    }
+
+    pub async fn set_quality(&self, quality: AudioQuality) -> Result<()> {
+        self.config.write().await.quality = quality;
+        Ok(())
+    }
+
+    pub async fn start_streaming(&self) -> Result<()> {
+        Err(AppError::AudioError(audio_disabled_message()))
+    }
+
+    pub async fn stop_streaming(&self) -> Result<()> {
+        Ok(())
+    }
+
+    pub async fn is_streaming(&self) -> bool {
+        false
+    }
+
+    pub async fn status(&self) -> AudioStatus {
+        let config = self.config.read().await.clone();
+        AudioStatus {
+            enabled: false,
+            streaming: false,
+            device: None,
+            quality: config.quality,
+            subscriber_count: 0,
+            error: Some(audio_disabled_message()),
+        }
+    }
+
+    pub async fn subscribe_opus(&self) -> Option<mpsc::Receiver<Arc<OpusFrame>>> {
+        None
+    }
+
+    pub async fn set_enabled(&self, enabled: bool) -> Result<()> {
+        self.config.write().await.enabled = enabled;
+        Ok(())
+    }
+
+    pub async fn update_config(&self, mut new_config: AudioControllerConfig) -> Result<()> {
+        new_config.enabled = false;
+        *self.config.write().await = new_config;
+        Ok(())
+    }
+
+    pub async fn shutdown(&self) -> Result<()> {
+        Ok(())
+    }
+}
+
+impl Default for AudioController {
+    fn default() -> Self {
+        Self::new(AudioControllerConfig::default())
+    }
+}
