 use crate::state::AppState;
 
 use super::apply::{apply_hid_config, try_apply_lock, ConfigApplyOptions};
@@ -16,6 +16,20 @@ pub async fn update_hid_config(
     State(state): State<Arc<AppState>>,
     Json(req): Json<HidConfigUpdate>,
 ) -> Result<Json<HidConfig>> {
+    let requests_otg = matches!(req.backend.as_ref(), Some(HidBackend::Otg))
+        || req.otg_udc.is_some()
+        || req.otg_descriptor.is_some()
+        || req.otg_profile.is_some()
+        || req.otg_endpoint_budget.is_some()
+        || req.otg_functions.is_some()
+        || req.otg_keyboard_leds.is_some();
+
+    if crate::platform::host_only_mode() && requests_otg {
+        return Err(AppError::BadRequest(
+            "OTG HID is disabled by this host-only firmware".to_string(),
+        ));
+    }
+
     req.validate()?;
 
     let _apply_guard = try_apply_lock(&state.config_apply_locks.otg, "otg")?;
