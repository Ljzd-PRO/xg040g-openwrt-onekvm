 //! Linux platform capabilities.
 
-use super::{FeatureCapability, PlatformCapabilities, PlatformMode};
+use super::{
+    host_only_mode, software_only_mode, FeatureCapability, PlatformCapabilities, PlatformMode,
+};
 
 pub fn capabilities() -> PlatformCapabilities {
+    let host_only = host_only_mode();
+    let encoder = if software_only_mode() {
+        FeatureCapability::available(["software"])
+    } else {
+        FeatureCapability::available([
+            "software", "vaapi", "nvenc", "qsv", "amf", "rkmpp", "v4l2m2m",
+        ])
+    };
+    let hid = if host_only {
+        FeatureCapability::available(["ch9329", "none"])
+    } else {
+        FeatureCapability::available(["otg", "ch9329", "none"])
+    };
+    let otg_reason = "Disabled by the XG-040G-MD host-only firmware profile";
+
     PlatformCapabilities {
         mode: PlatformMode::Linux,
         mode_label: PlatformMode::Linux.label(),
         video_capture: FeatureCapability::available(["v4l2"]),
-        encoder: FeatureCapability::available([
-            "software", "vaapi", "nvenc", "qsv", "amf", "rkmpp", "v4l2m2m",
-        ]),
-        hid: FeatureCapability::available(["otg", "ch9329", "none"]),
+        encoder,
+        hid,
         atx: FeatureCapability::available(["gpio", "usb_relay", "serial", "wol", "none"]),
-        msd: FeatureCapability::available(["configfs"]),
-        otg: FeatureCapability::available(["configfs"]),
+        msd: if host_only {
+            FeatureCapability::unsupported(otg_reason)
+        } else {
+            FeatureCapability::available(["configfs"])
+        },
+        otg: if host_only {
+            FeatureCapability::unsupported(otg_reason)
+        } else {
+            FeatureCapability::available(["configfs"])
+        },
         audio: FeatureCapability::available(["alsa"]),
         rustdesk: FeatureCapability::available(["builtin"]),
         vnc: FeatureCapability::available(["builtin", "tight_jpeg", "h264"]),
diff --git a/src/platform/mod.rs b/src/platform/mod.rs
index 8794c26..fed14b7 100644
--- a/src/platform/mod.rs
+++ b/src/platform/mod.rs
@@ -14,3 +14,22 @@ pub mod usb_reset;
 pub mod windows;
 
 pub use capabilities::{FeatureCapability, PlatformCapabilities, PlatformMode};
+
+fn env_flag(name: &str) -> bool {
+    std::env::var(name)
+        .map(|value| {
+            matches!(
+                value.trim().to_ascii_lowercase().as_str(),
+                "1" | "true" | "yes" | "on"
+            )
+        })
+        .unwrap_or(false)
+}
+
+pub fn host_only_mode() -> bool {
+    env_flag("ONE_KVM_FORCE_HOST_ONLY")
+}
+
+pub fn software_only_mode() -> bool {
+    env_flag("ONE_KVM_FORCE_SOFTWARE_ONLY")
+}
