#!/bin/sh /etc/rc.common
# shellcheck disable=SC2034,SC3043

START=95
USE_PROCD=1

start_service() {
	local enabled device bind_address port

	config_load xg040g-kvm
	config_get_bool enabled stream enabled 0
	config_get device stream device /dev/video0
	config_get bind_address stream bind_address 0.0.0.0
	config_get port stream port 8082

	[ "$enabled" = "1" ] || return 0
	[ -e "$device" ] || {
		logger -t kvm-ustreamer "$device not present"
		return 0
	}
	case "$port" in
		''|*[!0-9]*) port=8082 ;;
	esac
	[ "$port" -ge 1 ] 2>/dev/null && [ "$port" -le 65535 ] 2>/dev/null || port=8082

	procd_open_instance
	procd_set_param command /usr/bin/ustreamer --device="$device" --host="$bind_address" --port="$port"
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

service_triggers() {
	procd_add_reload_trigger xg040g-kvm
}
