#!/bin/sh
set -eu

STORE="${KVMSTORE:-/mnt/kvmstore}"

usage() {
	echo "Usage: kvm-lite-setup [status|apply]"
}

ensure_dirs() {
	mkdir -p "$STORE/tftp" "$STORE/netboot" "$STORE/iso" "$STORE/cloud-cache" "$STORE/secrets"
	mkdir -p /www
	rm -f /www/kvmboot
	ln -s "$STORE/netboot" /www/kvmboot
}

configure_fstab() {
	uci -q delete fstab.kvmstore || true
	uci set fstab.kvmstore='mount'
	uci set fstab.kvmstore.target="$STORE"
	uci set fstab.kvmstore.label='KVMSTORE'
	uci set fstab.kvmstore.enabled='1'
	uci set fstab.kvmstore.enabled_fsck='0'
	uci set fstab.kvmstore.options='rw,noatime'
	uci commit fstab
	/etc/init.d/fstab enable >/dev/null 2>&1 || true
	block mount >/dev/null 2>&1 || true
}

verify_pxe_network() {
	[ "$(uci -q get network.pxe.device)" = 'br-pxe' ] && \
		[ "$(uci -q get network.pxe.proto)" = 'static' ] && \
		uci -q get network.br_pxe.ports | grep -qw lan4 && return 0

	echo 'LAN4 PXE defaults are missing. Run xg040g-network-mode apply-default --force.' >&2
	return 1
}

status() {
	echo "KVMSTORE=$STORE"
	if grep -qs " $STORE " /proc/mounts; then
		echo "STORE_MOUNTED=1"
	else
		echo "STORE_MOUNTED=0"
	fi
	[ -L /www/kvmboot ] && echo "HTTP_LINK=/www/kvmboot -> $(readlink /www/kvmboot)" || echo "HTTP_LINK=missing"
	uci -q show network.pxe || true
	uci -q show network.br_pxe || true
	/usr/sbin/xg040g-pxe-uplink status 2>/dev/null || true
	[ -f /etc/dnsmasq.d/kvm-pxe.conf ] && echo 'PXE_DNSMASQ_SNIPPET=/etc/dnsmasq.d/kvm-pxe.conf' || echo 'PXE_DNSMASQ_SNIPPET=missing'
}

cmd="${1:-status}"
case "$cmd" in
	status)
		status
		;;
	apply)
		verify_pxe_network
		ensure_dirs
		configure_fstab
		/etc/init.d/xg040g-pxe-http restart >/dev/null 2>&1 || true
		/etc/init.d/dnsmasq restart >/dev/null 2>&1 || true
		status
		;;
	*)
		usage >&2
		exit 64
		;;
esac
