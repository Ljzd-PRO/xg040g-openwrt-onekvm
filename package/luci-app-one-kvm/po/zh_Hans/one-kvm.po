msgid "One-KVM"
msgstr "One-KVM"

msgid "One-KVM Status"
msgstr "One-KVM 状态"

msgid "Host-only One-KVM service for UVC/MS2109 video capture and CH9329 serial HID. OTG and USB gadget mass-storage are disabled on this firmware."
msgstr "面向 UVC/MS2109 视频采集和 CH9329 串口 HID 的 host-only One-KVM 服务。本固件禁用 OTG 和 USB gadget 虚拟存储。"

msgid "Enable service"
msgstr "启用服务"

msgid "Bind address"
msgstr "监听地址"

msgid "HTTP port"
msgstr "HTTP 端口"

msgid "Data directory"
msgstr "数据目录"

msgid "Video device"
msgstr "视频设备"

msgid "HID backend"
msgstr "HID 后端"

msgid "CH9329 port"
msgstr "CH9329 端口"

msgid "CH9329 baudrate"
msgstr "CH9329 波特率"

msgid "Hybrid mouse mode"
msgstr "混合鼠标模式"

msgid "Hardware check"
msgstr "硬件检查"

msgid "Running binary version"
msgstr "当前运行文件版本"

msgid "Installed One-KVM APK"
msgstr "已安装 One-KVM APK"

msgid "Firmware ROM version"
msgstr "固件 ROM 内置版本"

msgid "Runtime ABI package"
msgstr "运行时 ABI 包版本"

msgid "LuCI package version"
msgstr "LuCI 包版本"

msgid "Overlay state"
msgstr "Overlay 覆盖状态"

msgid "Overlay override active"
msgstr "当前使用 Overlay 覆盖文件"

msgid "Matches firmware copy"
msgstr "与固件内置文件一致"

msgid "Active binary missing"
msgstr "当前运行文件缺失"

msgid "Firmware copy unavailable"
msgstr "固件内置副本不可用"

msgid "Active SHA256"
msgstr "当前文件 SHA256"

msgid "ROM SHA256"
msgstr "ROM 文件 SHA256"

msgid "Restore firmware binary"
msgstr "恢复固件内置程序"

msgid "Restore the active executable from /rom/usr/bin/one-kvm"
msgstr "从 /rom/usr/bin/one-kvm 恢复当前可执行文件"

msgid "Replace the active One-KVM program with the copy built into this firmware? The service will be stopped and restarted only when it is enabled in UCI."
msgstr "确定使用本固件内置副本替换当前 One-KVM 程序吗？恢复时会停止服务，仅当 UCI 中已启用服务时才重新启动。"

msgid "Restore"
msgstr "恢复"

msgid "Firmware binary restored."
msgstr "固件内置程序已恢复。"

msgid "Firmware binary restore failed."
msgstr "固件内置程序恢复失败。"

msgid "PXE port"
msgstr "PXE 端口"

msgid "PXE upstream access"
msgstr "PXE 上游访问"

msgid "Enabled through NAT"
msgstr "已通过 NAT 启用"

msgid "Local KVMSTORE only"
msgstr "仅访问本地 KVMSTORE"

msgid "Enable PXE uplink"
msgstr "启用 PXE 上游访问"

msgid "Disable PXE uplink"
msgstr "禁用 PXE 上游访问"

msgid "PXE clients will be routed to the upstream management network through NAT. LAN4 remains isolated from device management services."
msgstr "PXE 客户端将通过 NAT 访问上游管理网络。LAN4 仍无法访问设备管理服务。"

msgid "Failed to update PXE uplink."
msgstr "更新 PXE 上游访问失败。"

msgid "PXE uplink enabled."
msgstr "PXE 上游访问已启用。"

msgid "PXE uplink disabled."
msgstr "PXE 上游访问已禁用。"

msgid "One-KVM data directory"
msgstr "One-KVM 数据目录"

msgid "Reset One-KVM data"
msgstr "重置 One-KVM 数据"

msgid "Reset data"
msgstr "重置数据"

msgid "Resetting..."
msgstr "正在重置..."

msgid "Reset refused because One-KVM uses a custom data directory."
msgstr "One-KVM 使用了自定义数据目录，已拒绝重置。"

msgid "Reset refused because /etc/one-kvm is a symbolic link."
msgstr "/etc/one-kvm 是符号链接，已拒绝重置。"

msgid "Another One-KVM data reset is already running."
msgstr "另一个 One-KVM 数据重置操作正在执行。"

msgid "One-KVM did not stop; no data was deleted."
msgstr "One-KVM 未能停止，未删除任何数据。"

msgid "Data was reset, but One-KVM could not be restarted."
msgstr "数据已重置，但 One-KVM 无法重新启动。"

msgid "Delete all One-KVM data and return to setup"
msgstr "删除全部 One-KVM 数据并返回初始化"

msgid "Reset is only available when the data directory is /etc/one-kvm"
msgstr "仅当数据目录为 /etc/one-kvm 时才能重置"

msgid "This permanently deletes the One-KVM account, password, database, sessions, certificates, updates and every file under /etc/one-kvm."
msgstr "此操作将永久删除 One-KVM 账号、密码、数据库、会话、证书、更新缓存及 /etc/one-kvm 下的全部文件。"

msgid "OpenWrt settings, /etc/config/one-kvm, the firmware binary and KVMSTORE are not deleted."
msgstr "OpenWrt 设置、/etc/config/one-kvm、固件内置程序和 KVMSTORE 不会被删除。"

msgid "I understand that the One-KVM data cannot be recovered."
msgstr "我了解 One-KVM 数据删除后无法恢复。"

msgid "One-KVM data was reset. Complete setup again before use."
msgstr "One-KVM 数据已重置，请重新完成初始化后再使用。"

msgid "One-KVM data reset failed."
msgstr "One-KVM 数据重置失败。"

msgid "General"
msgstr "常规"

msgid "Cloud PXE"
msgstr "云端 PXE"

msgid "Serve boot files directly from any rclone remote over a read-only HTTP data plane. LAN4 remains isolated and no USB disk is required."
msgstr "通过只读 HTTP 数据面直接提供任意 rclone 远程存储中的启动文件。LAN4 仍保持隔离，且无需 USB 硬盘。"

msgid "Data plane"
msgstr "数据面"

msgid "Enable Cloud PXE"
msgstr "启用云端 PXE"

msgid "Active remote path"
msgstr "活动远程路径"

msgid "Use a named rclone remote followed by a path. Inline remotes are rejected."
msgstr "填写具名 rclone remote 及其路径；不允许 inline remote。"

msgid "rclone configuration"
msgstr "rclone 配置"

msgid "Paste standard rclone INI configuration. Multiple remote sections are supported; maximum size is 64 KiB."
msgstr "粘贴标准 rclone INI 配置。支持多个 remote，最大 64 KiB。"

msgid "Test unsaved configuration"
msgstr "测试未保存配置"

msgid "Save & Apply"
msgstr "保存并应用"

msgid "Clear configuration"
msgstr "清除配置"

msgid "Clear Cloud PXE configuration"
msgstr "清除云端 PXE 配置"

msgid "This stops Cloud PXE and permanently removes the saved rclone configuration, including credentials. Local KVMSTORE files are not deleted."
msgstr "这会停止云端 PXE，并永久删除已保存的 rclone 配置及凭据。本地 KVMSTORE 文件不会被删除。"

msgid "Remote test succeeded."
msgstr "远程存储测试成功。"

msgid "Remote test failed."
msgstr "远程存储测试失败。"

msgid "Cloud PXE configuration saved."
msgstr "云端 PXE 配置已保存。"

msgid "Failed to save Cloud PXE configuration."
msgstr "保存云端 PXE 配置失败。"

msgid "Cloud PXE configuration cleared."
msgstr "云端 PXE 配置已清除。"

msgid "Failed to clear Cloud PXE configuration."
msgstr "清除云端 PXE 配置失败。"

