{
	"luci-app-one-kvm": {
		"description": "Grant access to One-KVM configuration",
		"read": {
			"uci": [
				"one-kvm",
				"xg040g-kvm"
			],
			"ubus": {
				"luci.one-kvm": [
					"get_status",
					"get_version",
					"get_versions",
					"get_hwcheck",
					"get_pxe_settings",
					"get_cloud_pxe"
				],
				"file": [
					"exec",
					"stat"
				],
				"log": [
					"read"
				]
			},
			"file": {
				"/usr/bin/one-kvm": [
					"read"
				],
				"/usr/sbin/one-kvm-hwcheck": [
					"exec"
				],
				"/dev/video*": [
					"read"
				],
				"/dev/ch9329": [
					"read"
				]
			}
		},
		"write": {
			"uci": [
				"one-kvm",
				"xg040g-kvm"
			],
			"ubus": {
				"luci.one-kvm": [
					"service_action",
					"restore_firmware_binary",
					"set_pxe_port",
					"set_pxe_uplink",
					"reset_data",
					"test_cloud_pxe_config",
					"save_cloud_pxe",
					"cloud_pxe_action",
					"clear_cloud_pxe"
				]
			},
			"file": {
				"/etc/init.d/one-kvm start": [
					"exec"
				],
				"/etc/init.d/one-kvm stop": [
					"exec"
				],
				"/etc/init.d/one-kvm restart": [
					"exec"
				],
				"/etc/init.d/one-kvm reload": [
					"exec"
				],
				"/etc/init.d/one-kvm enable": [
					"exec"
				],
				"/etc/init.d/one-kvm disable": [
					"exec"
				],
				"/usr/sbin/one-kvm-restore-firmware": [
					"exec"
				],
				"/usr/sbin/one-kvm-reset-data": [
					"exec"
				],
				"/usr/sbin/xg040g-pxe-uplink": [
					"exec"
				],
				"/usr/sbin/xg040g-network-mode": [
					"exec"
				],
				"/usr/sbin/xg040g-cloud-pxe": [
					"exec"
				]
			}
		}
	}
}
