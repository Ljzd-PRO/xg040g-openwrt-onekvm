#!/bin/sh /etc/rc.common
# shellcheck disable=SC2034,SC3043

START=96
USE_PROCD=1

start_service() {
	local enabled remote_path pxe_port
	config_load xg040g-kvm
	config_get_bool enabled cloud_pxe enabled 0
	config_get remote_path cloud_pxe remote_path ''
	/usr/sbin/xg040g-cloud-pxe install-assets >/dev/null
	[ "$enabled" = '1' ] || return 0
	pxe_port="$(uci -q get xg040g-management.pxe.port || echo none)"
	[ "$pxe_port" != 'none' ] || return 0
	[ "$(uci -q get network.pxe.device || true)" = 'br-pxe' ] || return 0
	/usr/sbin/xg040g-cloud-pxe validate-saved >/dev/null

	procd_open_instance
	procd_set_param command /usr/bin/rclone serve http
	procd_append_param command --config /etc/xg040g/rclone.conf
	procd_append_param command --addr 10.40.0.1:8083 --read-only
	procd_append_param command --vfs-cache-mode off --buffer-size 4M
	procd_append_param command --vfs-read-chunk-size 16M
	procd_append_param command --vfs-read-chunk-size-limit 64M
	procd_append_param command --dir-cache-time 10m --poll-interval 0
	procd_append_param command "$remote_path"
	procd_set_param respawn 3600 5 3
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_set_param limits core=0
	procd_close_instance
}

service_triggers() {
	procd_add_reload_trigger xg040g-kvm xg040g-management network
	procd_add_raw_trigger "interface.pxe.up" 1000 /etc/init.d/xg040g-cloud-pxe restart
}
