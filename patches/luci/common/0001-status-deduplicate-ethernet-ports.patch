--- a/modules/luci-mod-status/htdocs/luci-static/resources/view/status/include/29_ports.js
+++ b/modules/luci-mod-status/htdocs/luci-static/resources/view/status/include/29_ports.js
@@ -393,6 +393,19 @@ return baseclass.extend({
 			}
 		}
 
+		/* Multiple logical interfaces may share one bridge. The builtin port
+		 * RPC can report its physical members once per logical interface. */
+		const seen_ports = new Set();
+		known_ports = known_ports.filter((port) => {
+			const name = port.netdev.getName();
+
+			if (seen_ports.has(name))
+				return false;
+
+			seen_ports.add(name);
+			return true;
+		});
+
 		known_ports.sort(function(a, b) {
 			return L.naturalCompare(a.device, b.device);
 		});

