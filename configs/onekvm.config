CONFIG_TARGET_airoha=y
CONFIG_TARGET_airoha_an7581=y
CONFIG_TARGET_airoha_an7581_DEVICE_nokia_xg-040g-md-tcboot=y
CONFIG_TARGET_ROOTFS_INITRAMFS=y
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_BUILD_PATENTED=y
CONFIG_IMAGEOPT=y
CONFIG_PREINITOPT=y
CONFIG_TARGET_PREINIT_TIMEOUT=12

CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-package-manager=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y
CONFIG_PACKAGE_luci-i18n-package-manager-zh-cn=y
CONFIG_PACKAGE_luci-i18n-one-kvm-zh-cn=y
CONFIG_PACKAGE_luci-app-statistics=y
CONFIG_PACKAGE_luci-i18n-statistics-zh-cn=y
CONFIG_PACKAGE_luci-theme-bootstrap=y
CONFIG_LUCI_LANG_zh_Hans=y

CONFIG_PACKAGE_airoha-en7581-npu-firmware=y
CONFIG_PACKAGE_dropbear=y
CONFIG_PACKAGE_uhttpd=y
CONFIG_PACKAGE_uhttpd-mod-ubus=y
CONFIG_PACKAGE_ubi-utils=y
CONFIG_PACKAGE_uboot-envtools=y

CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-video-core=y
CONFIG_PACKAGE_kmod-video-uvc=y
CONFIG_PACKAGE_usbutils=y
CONFIG_PACKAGE_v4l-utils=y
CONFIG_PACKAGE_ustreamer=y

# PXE and network diagnostics.
# CONFIG_PACKAGE_dnsmasq is not set
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_ip-bridge=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y

# USB3 storage repository for PXE/iPXE files and ISO assets.
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_kmod-scsi-core=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_e2fsprogs=y
CONFIG_PACKAGE_parted=y
CONFIG_PACKAGE_smartmontools=y

# CH9329 boards normally expose a CH340/CH341 USB serial adapter.
CONFIG_PACKAGE_kmod-usb-serial=y
CONFIG_PACKAGE_kmod-usb-serial-ch341=y
CONFIG_PACKAGE_kmod-usb-serial-cp210x=y
CONFIG_PACKAGE_kmod-usb-serial-ftdi=y
CONFIG_PACKAGE_kmod-usb-serial-pl2303=y
CONFIG_PACKAGE_kmod-usb-acm=y
CONFIG_PACKAGE_coreutils-stty=y
CONFIG_PACKAGE_picocom=y

# Cloud mirror support. Secrets live on the external disk, not in the image.
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_kmod-fuse=y
CONFIG_PACKAGE_fuse3-utils=y
CONFIG_PACKAGE_rclone=y
CONFIG_PACKAGE_rclone-config=y
CONFIG_GOLANG_EXTERNAL_BOOTSTRAP_ROOT="/usr/local/go"
# CONFIG_GOLANG_BUILD_BOOTSTRAP is not set

# Native One-KVM and LuCI management page.
CONFIG_PACKAGE_one-kvm=y
CONFIG_PACKAGE_luci-app-one-kvm=y
CONFIG_PACKAGE_xg040g-kvm-support=y
CONFIG_PACKAGE_xg040g-cloud-pxe=y
CONFIG_PACKAGE_xg040g-onekvm-runtime=y
CONFIG_PACKAGE_xg040g-switch-management=y
CONFIG_PACKAGE_xg040g-monitoring-defaults=y
CONFIG_PACKAGE_rpcd-mod-ucode=y

# Volatile LuCI/collectd history for CPU, memory, load, interfaces and the
# AN7581 cpu-thermal zone. RRD files stay in /tmp to avoid flash wear.
CONFIG_PACKAGE_collectd-mod-thermal=y

# mDNS hostname and RFC3927 fallback for the DHCP-managed switch.
CONFIG_PACKAGE_avahi-autoipd=y
CONFIG_PACKAGE_avahi-nodbus-daemon=y

# Complete host-only One-KVM runtime. Optional services remain disabled until
# One-KVM starts them explicitly.
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_ttyd=y
CONFIG_PACKAGE_gostc=y
CONFIG_PACKAGE_easytier-core=y
CONFIG_PACKAGE_frpc=y
CONFIG_PACKAGE_kmod-tun=y

# Native audio and all four software video encoders. RKMPP remains disabled.
CONFIG_PACKAGE_kmod-sound-core=y
CONFIG_PACKAGE_kmod-usb-audio=y
CONFIG_PACKAGE_alsa-lib=y
CONFIG_PACKAGE_alsa-utils=y
CONFIG_PACKAGE_libopus=y
CONFIG_PACKAGE_libyuv=y
CONFIG_PACKAGE_libx264=y
CONFIG_PACKAGE_libx265=y
CONFIG_PACKAGE_libvpx=y
CONFIG_PACKAGE_libffmpeg-onekvm=y
# CONFIG_PACKAGE_libffmpeg-full is not set
# CONFIG_PACKAGE_libffmpeg-mini is not set
CONFIG_PACKAGE_libv4l=y
CONFIG_PACKAGE_libjpeg-turbo=y
CONFIG_PACKAGE_libudev-zero=y
CONFIG_PACKAGE_libdrm=y
# CONFIG_PACKAGE_libva is not set

# GPIO, hidraw and common USB serial adapters cover all One-KVM ATX backends.
CONFIG_PACKAGE_gpiod-tools=y
CONFIG_PACKAGE_kmod-hid=y
CONFIG_PACKAGE_kmod-hid-generic=y
CONFIG_PACKAGE_kmod-usb-hid=y

# Host-only route: keep AN7581 UDC/gadget experiments out of this firmware.
# CONFIG_PACKAGE_kmod-usb-mtu3 is not set
# CONFIG_PACKAGE_kmod-usb-gadget is not set
# CONFIG_PACKAGE_kmod-usb-gadget-hid is not set
# CONFIG_PACKAGE_kmod-usb-gadget-mass-storage is not set
